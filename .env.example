# ============================================================
# .env — CẤU HÌNH RIÊNG THEO MÁY. KHÔNG BAO GIỜ COMMIT.
# ------------------------------------------------------------
# Copy file này thành `.env` (installer tự làm nếu chưa có) rồi sửa.
# `.env` đã nằm trong .gitignore -> không lên GitHub. `.env.example` (file này)
# chỉ chứa placeholder, an toàn để public.
#
# Server tự nạp .env lúc khởi động (powerbi_agent/app.py -> load_dotenv).
# => MỌI tinh chỉnh theo máy đặt Ở ĐÂY, KHÔNG nhét vào cấu hình host
#    (~/.codex/config.toml, ~/.claude.json) — host chỉ giữ PYTHONUNBUFFERED=1.
# ============================================================

# --- Power BI Service (Cloud) — CHỈ cần nếu query dataset trên cloud ---
# Tạo Azure Entra ID App Registration rồi điền vào.
# Để trống nếu chỉ dùng Power BI Desktop local.
TENANT_ID=your-azure-tenant-guid
CLIENT_ID=your-entra-app-client-guid
CLIENT_SECRET=your-entra-app-client-secret-value

# --- Đường dẫn theo máy (bỏ trống = tự dò) ---
# Thư mục chứa ADOMD.NET DLL — chỉ set khi installer báo không tự tìm thấy.
# ADOMD_LIB_DIR=C:\Program Files\Microsoft.NET\ADOMD.NET\160

# Knowledge Dir: nơi lưu tri thức dự án (trỏ vào Brain / knowledge base của bạn).
# POWERBI_KNOWLEDGE_DIR=C:\Users\<you>\Brain\knowledge\powerbi

# Thư mục chứa các template KIT bổ sung (kit.json + blocks/ — tạo bằng distill_template).
# Mặc định tool đã đọc templates/ trong repo; trỏ thêm vào kho kit riêng của bạn nếu có.
# POWERBI_TEMPLATES_DIR=C:\Users\<you>\Brain\templates\powerbi

# Nơi ghi output khi distill model/report.
# POWERBI_DISTILL_DIR=C:\Users\<you>\Desktop\pbi-distill

# Nơi ghi audit log các truy vấn DAX đã chạy (mặc định: ~/.powerbi-agent/audit — NGOÀI repo).
# POWERBI_AUDIT_DIR=C:\Users\<you>\powerbi-audit

# --- Chính sách an toàn dữ liệu (mặc định đã an toàn) ---
# 1 = chỉ trả kết quả dạng tổng hợp, không trả dữ liệu thô mức dòng.
# Đặt 0 để tắt — CHỈ làm khi dataset chắc chắn không có PII.
# POWERBI_AGGREGATE_ONLY=1

# File policy thật theo máy/dự án (khai báo cột PII nhạy cảm).
# policy.json đã bị gitignore -> không public.
# POWERBI_POLICY_FILE=C:\Users\<you>\.mcp\powerbi-mcp\policy.json

# Trần số dòng trả về cho một truy vấn.
# POWERBI_MAX_ROWS=1000

# Trần số dòng khi liệt kê giá trị của một cột dimension.
# POWERBI_DIMENSION_ROW_CAP=200
